{
  "rules": {
    "riders": {
      ".read": true,
      ".write": true
    },
    "families": {
      "$familyId": {
        ".read": "auth !== null",
        ".write": "auth !== null"
      }
    },
    "invites": {
      "$code": {
        ".read": "auth !== null",
        ".write": "auth !== null"
      }
    },
    "users": {
      "$uid": {
        ".read": "auth !== null",
        ".write": "auth !== null && auth.uid === $uid"
      }
    },
    "config": {
      ".read": true,
      ".write": false
    }
  }
}
