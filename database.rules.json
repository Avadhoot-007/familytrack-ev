{
  "rules": {
    "riders": {
      ".read": true,
      "$riderId": {
        ".write": "auth !== null",
        "location": {
          ".validate": "newData.hasChildren(['lat', 'lon', 'battery', 'timestamp'])"
        },
        "profile": {
          ".validate": "newData.hasChildren(['name'])"
        },
        "trips": {
          "$tripId": {
            ".validate": "newData.hasChildren(['timestamp', 'distanceKm', 'score'])"
          }
        },
        "tripHistory": {
          "$tripId": {
            ".write": "auth !== null"
          }
        },
        "coachingTips": {
          "$tipId": {
            ".validate": "newData.hasChildren(['title', 'message', 'sentAt'])"
          }
        }
      }
    },
    "families": {
      "$familyId": {
        ".read": "auth !== null && root.child('families').child($familyId).child('members').child(auth.uid).exists()",
        ".write": "auth !== null && (root.child('families').child($familyId).child('members').child(auth.uid).exists() || !data.exists())"
      }
    },
    "invites": {
      "$code": {
        ".read": "auth !== null",
        ".write": "auth !== null"
      }
    },
    "users": {
      "$uid": {
        ".read": "auth !== null && auth.uid === $uid",
        ".write": "auth !== null && auth.uid === $uid"
      }
    }
  }
}