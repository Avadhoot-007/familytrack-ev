{
  "rules": {
    "riders": {
      ".read": true,
      ".write": true
    },
    "families": {
      "$familyId": {
        ".read": "auth !== null && root.child('families').child($familyId).child('members').child(auth.uid).exists()",
        ".write": "auth !== null && (root.child('families').child($familyId).child('members').child(auth.uid).exists() || !data.exists())"
      }
    },
    "invites": {
      "$code": {
        ".read": "auth !== null",
        ".write": "auth !== null"
      }
    },
    "users": {
      "$uid": {
        ".read": "auth !== null",
        ".write": "auth !== null && auth.uid === $uid"
      }
    }
  }
}